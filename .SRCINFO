pkgbase = iwlwifi-lar-patched
	pkgdesc = Patched Intel iwlwifi family modules with lar_disable support for Arch Linux kernels
	pkgver = 7.0.2
	pkgrel = 1
	url = https://github.com/TenkyuChimata/iwlwifi-lar-patched
	install = iwlwifi-lar-patched.install
	arch = x86_64
	license = GPL-2.0-only
	makedepends = bc
	makedepends = kmod
	makedepends = patch
	depends = linux=7.0.2.arch1-1
	depends = linux-headers=7.0.2.arch1-1
	depends = zstd
	optdepends = mkinitcpio: rebuild initramfs for mkinitcpio-based systems
	optdepends = dracut: rebuild initramfs or UKI for dracut-based systems
	optdepends = systemd: required for kernel-install based workflows
	optdepends = sbctl: re-sign boot artifacts for Secure Boot systems if needed
	options = !debug
	source = https://cdn.kernel.org/pub/linux/kernel/v7.x/linux-7.0.2.tar.xz
	source = 0001-iwlwifi-add-lar_disable.patch
	source = iwlwifi-lar.conf
